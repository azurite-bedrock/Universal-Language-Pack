{
    "$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.4.json",
    "author": "Azurite",
    "name": "Universal-Language-Pack",
    "packs": {
        "behaviorPack": "./packs/BP",
        "resourcePack": "./packs/RP"
    },
    "regolith": {
        "dataPath": "./packs/data",
        "filterDefinitions": {
            "shush": {
                "url": "github.com/azurite-bedrock/regolith-filters",
                "version": "1.0.3"
            },
            "marathon": {
                "url": "github.com/azurite-bedrock/regolith-filters",
                "version": "1.3.0"
            },
            "parcel": {
                "url": "github.com/azurite-bedrock/regolith-filters",
                "version": "1.1.1"
            }
        },
        "formatVersion": "1.4.0",
        "profiles": {
            "base": {
                "export": {
                    "readOnly": false,
                    "target": "development"
                },
                "filters": [
                    {
                        "filter": "shush",
                        "settings": {
                            "minify": true
                        }
                    },
                    {
                        "filter": "marathon"
                    }
                ]
            },
            "dev": {
                "export": {
                    "build": "standard",
                    "readOnly": false,
                    "target": "development"
                },
                "filters": [
                    {
                        "profile": "base"
                    }
                ]
            },
            "release": {
                "export": {
                    "readOnly": false,
                    "target": "development"
                },
                "filters": [
                    {
                        "profile": "base"
                    }
                ]
            },
            "pack": {
                "export": {
                    "readOnly": false,
                    "target": "local"
                },
                "filters": [
                    {
                        "profile": "release"
                    },
                    {
                        "filter": "parcel",
                        "settings": {
                            "content_type": "resource_pack",
                            "output": "build/${config.name}-${git.tag ?? 'dev'}.mcpack",
                            "compression_level": 6,
                            "update_version_from_tag": true
                        }
                    }
                ]
            }
        }
    }
}
